                <span className={`px-2 py-1 text-xs font-medium rounded-full ${
                  course.status === 'published' ? 'bg-[#DCFCE7] text-[#1B8A44]' :
                  course.status === 'draft' ? 'bg-[#E2E8F0] text-[#475569]' :
                  'bg-[#F1F5F9] text-[#64748B]'
