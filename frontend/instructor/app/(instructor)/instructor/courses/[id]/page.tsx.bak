        </div>
      </div>

      {/* Secure File Viewer Modal */}
      {viewingMaterial && (
        <SecureFileViewer
          materialId={viewingMaterial.id}
          fileName={viewingMaterial.file_name}
          onClose={() => setViewingMaterial(null)}
        />
      )}
    </div>
  );
